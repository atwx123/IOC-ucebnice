{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "typescript",
            "tsconfig": "tsconfig.json",
            "option": "watch",
            "problemMatcher": [
                "$tsc-watch"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "label": "tsc: watch - tsconfig.json"
        },
        {
            "label": "copy-resources",
            "type": "shell",
            "command": "cp -R resources/* dist"
        },
        {
            "label": "build-dist",
            "dependsOrder": "sequence",
            "dependsOn": ["tsc: watch - tsconfig.json", "copy-resources"]
        },
        {
            "type": "typescript",
            "tsconfig": "tsconfig.json",
            "problemMatcher": [
                "$tsc"
            ],
            "group": {
                "kind": "build",
            },
            "label": "tsc: build - tsconfig.json"
        }
    ]
  }